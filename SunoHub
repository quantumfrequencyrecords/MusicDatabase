var BUILTIN_DB = [{"id": "angels_airwaves", "name": "Angels & Airwaves", "genres": ["Alternative Rock", "Space Rock", "Post-Punk", "Synth Rock", "Atmospheric Rock"], "era": "2005–present", "color": "#5b8dee", "bio": "Angels & Airwaves (ΛVΛ) is the side project of Tom DeLonge, formed after Blink-182 went on hiatus in 2005. DeLonge described the band as 'the most important rock band in the world,' claiming it would 'save people's lives' — a level of ambition that earned both ridicule and a fiercely devoted fanbase. The signature AVA sound: slow tempo (most songs under 100 BPM), vast reverb-soaked guitars, cinematic synthesizers, DeLonge's signature wide-vibrato tenor vocal, and lyrics obsessed with space, love, consciousness, and humanity's potential. The band is inseparable from DeLonge's broader multimedia universe: the Love film (2011), the Poet Anderson animated short film and novel (2014), and his UFO disclosure work through To The Stars Academy.", "producer_notes": "Jeff 'Critter' Newell produced We Don't Need to Whisper and I-Empire, establishing the signature vast cathedral-reverb sound. The Love albums were self-produced. The Dream Walker introduced Aaron Rubin and Ilan Rubin as co-producers — a major shift to rawer alternative rock. Lifeforms (2021) was co-produced by DeLonge and Brad Delson of Linkin Park — a brighter, more guitar-forward sound. All albums on DeLonge's To The Stars label except Lifeforms (Rise Records). No artist names in Suno style prompts.", "songs": [{"title": "Valkyrie Missile", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 90, "vibe": "Album opener · space-age atmosphere · 6:39 runtime · vast reverb cathedral production", "dna": "Opens the debut album at 6:39 — immediately establishing that AVA operates on a completely different scale than Blink-182. The title references the AGM-69 SKREET missile but functions as a metaphor for human potential launched into the unknown. Producer Jeff 'Critter' Newell's signature: every instrument drenched in vast reverb, the production sounding like it was recorded inside a cathedral on the surface of the moon. Slow tempo, wide-vibrato DeLonge vocal, layers of synthesizer and distorted guitar building over extended runtime.", "style_prompt": "Vast atmospheric space-rock, 90 BPM, Jeff Critter Newell cathedral-reverb production, slow-building opener energy, Tom DeLonge wide-vibrato tenor vocal, layers of reverb-soaked distorted guitar, cinematic synthesizer pads, extended 6-minute runtime permitted, post-punk meets space rock, slow tempo with enormous sonic scale, 2006 debut AVA sound", "lyric_prompt": "Write a slow, vast atmospheric space-rock song that opens an album — establishing a universe rather than just beginning a song. The lyric should feel like being launched into something enormous and unknown: space, potential, love, human consciousness. The language is cinematic and slightly grandiose — this band does not do restraint. The verses build a picture of something infinite. The chorus is the declaration of being part of something larger than yourself. Extended runtime permitted — let it breathe. Under 7 minutes."}, {"title": "Distraction", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 90, "vibe": "Second track · slow atmospheric build · love as cosmic distraction", "dna": "90 BPM. The second track on the debut, continuing the vast atmospheric sound established by Valkyrie Missile. The lyric uses distraction — being pulled from one's path by love — as a positive rather than negative force. A quintessential AVA slow-burn: patient, reverb-soaked, building.", "style_prompt": "Slow atmospheric space-rock, 90 BPM, Jeff Critter Newell vast reverb production, DeLonge wide-vibrato vocal, reverb-drenched guitar layers, cinematic synth pads, love-as-cosmic-distraction lyric, slow patient build, 2006 debut AVA sound", "lyric_prompt": "Write a slow atmospheric space-rock song about being completely distracted from everything by love — the way it overrides all other purposes and missions, pulls you from your path, and makes you grateful for the derailment. The narrator has found something that matters more than the plan. The language is vast and slightly cosmic — even ordinary love gets described in terms of stars and trajectories. Under 5:40."}, {"title": "Do It for Me Now", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 78, "vibe": "Slowest WDNTW track · desperate plea · DeLonge most vulnerable debut performance", "dna": "78 BPM — the slowest track on the debut. A desperate, direct plea — 'do it for me now.' DeLonge's most nakedly vulnerable performance on the album. The production is still vast but something more urgent and pleading exists underneath the reverb. One of the album's most emotionally direct moments.", "style_prompt": "Slow desperate atmospheric rock, 78 BPM, slowest debut track, DeLonge vulnerable pleading vocal, Jeff Critter Newell vast reverb, desperate-plea lyric, urgency underneath the atmospheric production, most emotionally direct debut moment, under 4:35", "lyric_prompt": "Write a slow, desperate rock song that is a direct urgent plea — asking someone (a person, the universe, love itself) to do something now, before it's too late. The urgency sits in tension with the vast slow production: the emotion is immediate even though the music breathes slowly. The narrator is not in control — they are asking, not demanding. Under 4:35."}, {"title": "The Adventure", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 70, "vibe": "Lead single · leaked via fan hacking DeLonge's email · AVA's defining statement", "dna": "The debut single — leaked after a fan hacked DeLonge's email, giving the band no choice but to release it. 70 BPM — the slowest of the WDNTW singles, which contributed to the culture-shock effect on Blink-182 fans expecting pop-punk. Peaked at number 4 on the Bubbling Under Hot 100. The Adventure established the AVA formula: slow vast build, multiple guitar layers, DeLonge's operatic vocal, lyrics about consciousness and human potential. Jeff Critter Newell produced.", "style_prompt": "Slow anthemic space-rock, 70 BPM, Jeff Critter Newell vast cathedral production, DeLonge wide-vibrato tenor at his most operatic, multiple reverb-drenched guitar layers, cinematic synth pads, human-potential-and-consciousness lyric, slow vast build to enormous chorus, AVA defining sound statement", "lyric_prompt": "Write the defining statement of this band's philosophy in song form — slow, vast, and completely certain that this music and this moment matter enormously. The lyric is about the adventure of human consciousness, love, and potential: the idea that life is an adventure worth taking, that love is the reason for everything, that waking up to what matters is the most important thing a person can do. The chorus should feel like being told the secret of the universe simply and directly. Under 5:15."}, {"title": "A Little's Enough", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 76, "vibe": "Second single · intimate ballad within vast production · love sustains everything", "dna": "Second single from the debut. One of the more intimate tracks on the album — the lyric arguing that a little love is enough to sustain everything. DeLonge at his most tender within the AVA context. The production still vast but the emotion is closer to the surface than on the more epic tracks.", "style_prompt": "Slow intimate atmospheric rock, 76 BPM, Jeff Critter Newell vast production serving intimacy, DeLonge tender vocal within reverb landscape, a-little-love-sustains-everything lyric, gentle but enormous production scale, under 4:50", "lyric_prompt": "Write a slow atmospheric rock song about the sufficiency of small love — the argument that a little love, honestly given, is enough to sustain a person through anything. The narrator doesn't need grand gestures. They need the specific, quiet, reliable presence of someone. The production should feel vast but the emotion should feel intimate and honest. Under 4:50."}, {"title": "The War", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 86, "vibe": "Anti-war statement · love as the only weapon · DeLonge political consciousness", "dna": "One of the debut's more overtly political moments. DeLonge uses 'the war' as both literal (the Iraq War was ongoing at the time) and metaphorical — the internal war, the war between fear and love. The production matches the content: heavy, dark, more aggressive than the surrounding album tracks.", "style_prompt": "Atmospheric heavy space-rock, 86 BPM, Jeff Critter Newell production at its heaviest, DeLonge vocal more aggressive than usual, anti-war lyric with love-as-counterforce, darker production than surrounding album tracks, under 5:10", "lyric_prompt": "Write an atmospheric heavy rock song about war — both the literal wars fought by governments and the internal war between fear and love, between giving up and holding on. The narrator argues that love is the only real weapon that matters. The tone is angry and idealistic simultaneously — furious at what the world is and certain of what it could be. Under 5:10."}, {"title": "The Gift", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 82, "vibe": "Love as given gift · philosophical lyric · mid-album emotional core", "dna": "The lyric frames love as a gift — something given rather than earned or taken. One of the more philosophically developed debut lyrics. A slower, more meditative track within the album. An acoustic version was released on the I-Empire vinyl bonus tracks.", "style_prompt": "Slow meditative atmospheric rock, 82 BPM, Jeff Critter Newell reverb production, DeLonge philosophical vocal, love-as-gift lyric, meditative rather than anthemic energy, under 5:05", "lyric_prompt": "Write a slow meditative atmospheric rock song about love as a gift — something given freely without condition or expectation of return. The narrator is trying to understand what love actually is, and arrives at the conclusion that it is the most fundamental act of giving. The tone is thoughtful rather than emotional. Under 5:05."}, {"title": "It Hurts", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 84, "vibe": "Pain of love · honesty about the cost · third single", "dna": "Third single from the debut. The most direct emotional admission on the album — it hurts. Despite the vast production, the lyric is simple and honest: love hurts, missing someone hurts, being alive hurts. The counterpoint to the album's more philosophical tracks. An 'It Hurts' short film was released as part of the early AVA multimedia project.", "style_prompt": "Atmospheric honest rock, 84 BPM, Jeff Critter Newell vast production, DeLonge straightforward pain-admission vocal, love-hurts lyric within philosophical AVA framework, simple honest emotion inside enormous production, under 4:15", "lyric_prompt": "Write an atmospheric rock song that is simply and directly honest: it hurts. Love hurts, absence hurts, trying to hold onto something that won't stay hurts. The narrator has dropped the philosophical framework and is just admitting the pain. Despite the vast production, the lyric should feel simple and unguarded. Under 4:15."}, {"title": "Good Day", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 84, "vibe": "Counterintuitively hopeful · it will be a good day · affirmation within pain", "dna": "One of the debut's more hopeful moments — the simple declaration that it will be a good day, despite or because of everything. A counterpoint to the heavier and more philosophical debut tracks. The production is slightly more open and bright than the surrounding songs.", "style_prompt": "Atmospheric hopeful space-rock, 84 BPM, Jeff Critter Newell production slightly brighter than surrounding tracks, DeLonge affirmative vocal, it-will-be-a-good-day lyric, hopeful-within-enormous-scale, under 4:30", "lyric_prompt": "Write an atmospheric rock song built on the simple but earnest declaration that today will be a good day — not because everything is fine but because the narrator has decided to meet it that way. The optimism is deliberate, not naive. Despite the vast slow production, the emotional core is warm and forward-facing. Under 4:30."}, {"title": "Start the Machine", "album": "We Don't Need to Whisper", "year": 2006, "bpm": 84, "vibe": "Album closer · the machine of human civilization · documentary shares this title", "dna": "Closes the debut album. 'The machine' functions as a metaphor for human civilization, consciousness, and the whole enterprise of being alive. The AVA documentary film Start the Machine (2008) shares this title — testament to its importance within the band's mythology. A fitting closer: slower, more reflective, looking at the full scope of what the album has been about.", "style_prompt": "Slow reflective album-closing atmospheric rock, 84 BPM, Jeff Critter Newell closing-statement production, DeLonge contemplative vocal, human-civilization-as-machine metaphor, album-closer emotional resolution, vast reverb, under 4:15", "lyric_prompt": "Write a slow reflective closing song about the whole machine of human civilization — all of it, the love and the war, the dreams and the failures, the people and their connections. The narrator is stepping back and looking at the entire scope of what it means to be human and alive. The closing declaration should feel like the last word on something important. Under 4:15."}, {"title": "Call to Arms", "album": "I-Empire", "year": 2007, "bpm": 94, "vibe": "I-Empire opener · rallying call · new band lineup · bigger ambition", "dna": "Opens I-Empire — the album recorded with new bassist Matt Wachter (replacing Ryan Sinn) joining DeLonge and David Kennedy. 'I-Empire' was DeLonge's concept of the individual as an empire unto themselves — one person capable of changing the world. Call to Arms establishes this philosophy immediately. The production remains vast but slightly more polished than the debut.", "style_prompt": "Atmospheric rallying space-rock, 94 BPM, Jeff Critter Newell I-Empire production — slightly more polished than debut, DeLonge wide-vibrato rallying vocal, individual-as-empire philosophy lyric, reverb-soaked guitar and synth layers, album-opening call-to-action energy, under 5 minutes", "lyric_prompt": "Write an atmospheric rock song that opens an album with a rallying call — addressing the individual directly and telling them they are more powerful than they know, that one person can be an empire, that waking up to your own potential is the most revolutionary act possible. The tone is inspiring and slightly grandiose. Under 5 minutes."}, {"title": "Everything's Magic", "album": "I-Empire", "year": 2007, "bpm": 98, "vibe": "Lead single · most requested on KROQ · most accessible AVA song · love makes everything magical", "dna": "Lead single from I-Empire. Described as 'a synth-rock anthem that resonates with a refreshing spirit and inspired energy.' Became the most requested song on California radio station KROQ. The most radio-accessible AVA song — brighter, more upbeat, with a singalong hook that doesn't require the listener to be patient with a slow build. The central philosophy: when you're in love, everything is magic. Peaked at number 4 on the Bubbling Under Hot 100.", "style_prompt": "Bright synth-rock anthem, 98 BPM, Jeff Critter Newell most radio-accessible production, DeLonge enthusiastic bright vocal, love-makes-everything-magical lyric, most upbeat AVA track, pulsing synth, melodic guitar lead, singalong hook, KROQ most-requested energy", "lyric_prompt": "Write a bright synth-rock anthem about the specific magic of being in love — how it transforms ordinary things into something extraordinary, how every moment feels significant, how the world looks different when you're seen by someone who loves you. This is AVA's most accessible song: not slow and philosophical but immediately joyful and hooky. The chorus must be singable by 10,000 people. Under 4 minutes."}, {"title": "Breathe", "album": "I-Empire", "year": 2007, "bpm": 98, "vibe": "Second track · the act of breathing as metaphor · space between moments", "dna": "98 BPM. The instruction to breathe — simply, consciously, right now — as a philosophical and practical act. One of the album's more meditative tracks despite the slightly higher BPM. The lyric explores the space between moments and the importance of being present.", "style_prompt": "Meditative atmospheric space-rock, 98 BPM, Jeff Critter Newell I-Empire production, DeLonge contemplative vocal, breathing-as-conscious-act lyric, space-between-moments theme, reverb-soaked guitar layers, under 4:30", "lyric_prompt": "Write an atmospheric rock song built on the instruction to breathe — simply, consciously, deliberately. The lyric explores what happens in that pause: the space between moments where everything becomes clear. The narrator is not in crisis — they are discovering the power of being present. Under 4:30."}, {"title": "Love Like Rockets", "album": "I-Empire", "year": 2007, "bpm": 88, "vibe": "Love as propulsive force · rocket metaphor · velocity and trajectory", "dna": "The rocket metaphor: love that launches you forward, that propels rather than grounds. One of the album's more kinetic tracks despite the slow BPM — the production has a forward momentum that the debut largely avoided. DeLonge's lyrics here blend his two obsessions: space/rockets and love.", "style_prompt": "Atmospheric kinetic space-rock, 88 BPM, Jeff Critter Newell I-Empire production, DeLonge space-and-love merged lyric, rocket-as-love-metaphor, forward-momentum production despite slow BPM, reverb-soaked cinematic, under 5:10", "lyric_prompt": "Write an atmospheric rock song about love as a rocket — a propulsive force that launches you into something new, gives you trajectory, lifts you from the gravity of your old self. The rocket is a metaphor for both space exploration and the feeling of being in love. The lyric should blend DeLonge's obsessions: the cosmos and human connection. Under 5:10."}, {"title": "Sirens", "album": "I-Empire", "year": 2007, "bpm": 86, "vibe": "Mythology meets love song · siren as the irresistible call · DeLonge's literary reach", "dna": "Uses the mythological sirens — the creatures whose song lured sailors to their deaths — as a metaphor for irresistible love. DeLonge at his most literary: pulling from Greek mythology to describe the experience of being unable to resist someone. The tension between danger and desire.", "style_prompt": "Slow mythological atmospheric rock, 86 BPM, Jeff Critter Newell production, DeLonge literary-mythological lyric, siren-as-irresistible-love metaphor, tension between danger and desire, reverb-soaked vast production, under 4:30", "lyric_prompt": "Write a slow atmospheric rock song using the siren myth — the irresistible call that draws sailors to their destruction — as a metaphor for love that you know is dangerous but cannot resist. The narrator knows what this will cost and moves toward it anyway. The beauty and the danger are inseparable. Under 4:30."}, {"title": "Secret Crowds", "album": "I-Empire", "year": 2007, "bpm": 86, "vibe": "Second single · secret communities of like-minded people · finding your people", "dna": "Second single from I-Empire. About the feeling of discovering that there are secret crowds of people who think and feel like you — that you are not alone in your outsider status. The 'secret crowds' are the people who get it, who feel deeply, who refuse to be ordinary. One of AVA's most beloved tracks for its message of belonging to a tribe of searchers.", "style_prompt": "Atmospheric uplifting space-rock, 86 BPM, Jeff Critter Newell I-Empire production, DeLonge vocal full of longing and connection, finding-your-tribe lyric, secret-crowds-of-like-minded-people theme, wide reverb guitar, synth pads, under 5:05", "lyric_prompt": "Write an atmospheric rock song abou