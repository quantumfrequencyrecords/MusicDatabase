function rebuildDB() {
  // Merge builtin + custom, custom overrides builtin by id
  var merged = BUILTIN_DB.slice();
  customArtists.forEach(function(ca) {
    var idx = merged.findIndex(function(a){return a.id===ca.id;});
    if (idx >= 0) merged[idx] = ca; else merged.push(ca);
  });
  DB = merged;
  // Tag all songs
  var accS={}, accL={};
  DB.forEach(function(a) {
    (a.songs||[]).forEach(function(s) {
      s.tags = extractTags(s);
      s.tags.style.forEach(function(t){accS[t]=(accS[t]||0)+1;});
      s.tags.lyric.forEach(function(t){accL[t]=(accL[t]||0)+1;});
    });
  });
  TC_STYLE = Object.keys(accS).map(function(k){return[k,accS[k]];}).sort(function(a,b){return b[1]-a[1];});
  TC_LYRIC = Object.keys(accL).map(function(k){return[k,accL[k]];}).sort(function(a,b){return b[1]-a[1];});
  var total = DB.reduce(function(n,a){return n+(a.songs||[]).length;},0);
  document.getElementById('stats-t').textContent = DB.length + ' artists · ' + total + ' songs';
  document.getElementById('songs-sub').textContent = total + ' songs';
  buildHome(); buildBrowse(); buildAllSongs();
}

