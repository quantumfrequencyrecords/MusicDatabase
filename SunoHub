<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Suno Hub">
<title>Suno Prompt Hub</title>
<style>
:root{
  --bg:#09090f;--surf:#0f0f1a;--card:#141421;--raise:#1a1a28;
  --bdr:#1e1e2e;--b2:#161622;--text:#e8e8f2;--t2:#7878a0;
  --mute:#3a3a55;--dim:#222235;--acc:#f0f0e8;
  --grn:#00e676;--g2:rgba(0,230,118,.14);--g3:rgba(0,230,118,.07);
  --red:#ff4757;--gold:#ffd700;
  --sans:-apple-system,"Helvetica Neue",Arial,sans-serif;
  --mono:"Menlo","Monaco","Courier New",monospace;
  --sat:env(safe-area-inset-top,0px);--sab:env(safe-area-inset-bottom,0px);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{height:100%;-webkit-text-size-adjust:100%}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;line-height:1.5;height:100%;overflow:hidden;overscroll-behavior:none;-webkit-tap-highlight-color:transparent}
button{cursor:pointer;font-family:var(--sans);border:none;background:none;color:inherit}
input,textarea,select{font-family:var(--sans)}
::-webkit-scrollbar{display:none}
.app{display:flex;flex-direction:column;height:100vh;height:100dvh;padding-top:var(--sat)}

/* TOP BAR */
.topbar{flex-shrink:0;background:rgba(9,9,15,.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(–bdr);padding:10px 16px;display:flex;align-items:center;gap:10px;z-index:100}
.logo{font-family:var(–mono);font-size:11px;letter-spacing:3px;color:var(–acc);white-space:nowrap;flex-shrink:0;font-weight:600;display:flex;align-items:center;gap:6px}
.pulse{width:7px;height:7px;border-radius:50%;background:var(–grn);animation:pulse 3s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.3;transform:scale(.5)}}
.sw{flex:1;position:relative}
.si{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(–mute);font-size:15px;pointer-events:none}
#qi{width:100%;padding:9px 36px 9px 34px;background:var(–surf);border:1px solid var(–bdr);border-radius:10px;color:var(–text);font-size:14px;outline:none;-webkit-appearance:none}
#qi:focus{border-color:var(–grn)}
#qi::placeholder{color:var(–mute)}
.sx{position:absolute;right:10px;top:50%;transform:translateY(-50%);color:var(–mute);font-size:18px;display:none;padding:4px}
#qi:not(:placeholder-shown)~.sx{display:block}

/* FILTER BAR */
.fbar{flex-shrink:0;display:none;align-items:center;gap:6px;padding:6px 16px 4px;background:var(–surf);border-bottom:1px solid var(–bdr);overflow-x:auto;white-space:nowrap}
.fbar.on{display:flex}
.afchip{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:14px;background:var(–g2);border:1px solid var(–grn);color:var(–grn);font-size:11px;flex-shrink:0}
.fbar-clear{flex-shrink:0;font-size:11px;color:var(–mute);font-family:var(–mono);margin-left:4px}

/* BODY / TABS */
.body{flex:1;overflow:hidden;display:flex;flex-direction:column}
.content{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain}
.screen{display:none}
.screen.on{display:block}
.tabbar{flex-shrink:0;background:rgba(9,9,15,.98);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-top:1px solid var(–bdr);display:flex;padding-bottom:var(–sab)}
.tab{flex:1;display:flex;flex-direction:column;align-items:center;padding:7px 0 4px;gap:2px;color:var(–mute);min-height:48px;font-size:8px;letter-spacing:.5px;text-transform:uppercase;font-family:var(–mono);transition:color .15s}
.tab.on{color:var(–grn)}
.tab-ic{font-size:18px;line-height:1}

/* GENRE TAGS */
.gtag{display:inline-block;padding:2px 7px;border-radius:4px;font-size:9px;font-family:var(–mono);letter-spacing:.5px;text-transform:uppercase}
.gt-country{background:rgba(232,148,58,.15);color:#e8943a;border:1px solid rgba(232,148,58,.3)}
.gt-punk{background:rgba(255,71,87,.15);color:#ff4757;border:1px solid rgba(255,71,87,.3)}
.gt-edm{background:rgba(0,180,216,.15);color:#00b4d8;border:1px solid rgba(0,180,216,.3)}
.gt-rock,.gt-metal{background:rgba(230,126,34,.15);color:#e67e22;border:1px solid rgba(230,126,34,.3)}
.gt-alt{background:rgba(155,89,182,.15);color:#9b59b6;border:1px solid rgba(155,89,182,.3)}
.gt-folk{background:rgba(139,195,74,.15);color:#8bc34a;border:1px solid rgba(139,195,74,.3)}
.gt-soul{background:rgba(233,30,99,.15);color:#e91e63;border:1px solid rgba(233,30,99,.3)}

/* PAGE HEADER */
.ph{padding:16px 16px 10px}
.ph-t{font-size:22px;font-weight:700;color:var(–acc);margin-bottom:2px}
.ph-s{font-size:12px;color:var(–t2)}
.statsbar{padding:8px 16px 0;font-size:10px;color:var(–mute);font-family:var(–mono)}

/* HOME GRID */
.agrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:10px 16px 24px}
.acard{background:var(–card);border:1px solid var(–bdr);border-radius:10px;padding:14px 12px;position:relative;overflow:hidden;min-height:90px;transition:transform .1s;-webkit-tap-highlight-color:transparent}
.acard::before{content:””;position:absolute;top:0;left:0;right:0;height:3px;border-radius:10px 10px 0 0}
.acard:active{transform:scale(.97)}
.ac-era{font-size:9px;color:var(–mute);font-family:var(–mono);margin-bottom:3px;margin-top:8px}
.ac-nm{font-size:13px;font-weight:700;color:var(–acc);margin-bottom:6px;line-height:1.2}
.ac-genres{display:flex;flex-wrap:wrap;gap:3px}
.fav-star{position:absolute;top:8px;right:8px;font-size:14px;color:var(–mute);padding:4px;line-height:1}
.fav-star.on{color:var(–gold)}

/* BROWSE */
.ftt-row{display:flex;margin:8px 16px 0;border-bottom:1px solid var(–bdr)}
.ftt{flex:1;padding:8px 0;text-align:center;font-size:11px;font-family:var(–mono);letter-spacing:1px;text-transform:uppercase;color:var(–mute);border-bottom:2px solid transparent;transition:all .15s}
.ftt.on{color:var(–grn);border-bottom-color:var(–grn)}
.bsearch{padding:8px 16px 0}
.bsearch input{width:100%;padding:9px 14px;background:var(–surf);border:1px solid var(–bdr);border-radius:10px;color:var(–text);font-size:13px;outline:none;-webkit-appearance:none}
.bsearch input:focus{border-color:var(–grn)}
.bsearch input::placeholder{color:var(–mute)}
.brc{padding:8px 16px 4px;font-size:10px;font-family:var(–mono)}
.fdim{margin:8px 16px 0;background:var(–card);border:1px solid var(–bdr);border-radius:10px;overflow:hidden}
.fdim-hd{display:flex;align-items:center;gap:10px;padding:12px 16px;min-height:50px;-webkit-tap-highlight-color:transparent;transition:background .1s}
.fdim-hd:active{background:var(–raise)}
.fdim-ic{font-size:15px;flex-shrink:0}
.fdim-lbl{flex:1;font-size:13px;font-weight:600;color:var(–text)}
.fdim-badge{font-size:9px;padding:2px 7px;border-radius:10px;background:var(–g2);border:1px solid var(–grn);color:var(–grn);font-family:var(–mono);flex-shrink:0}
.fdim-ct{font-size:10px;color:var(–mute);font-family:var(–mono);flex-shrink:0}
.fdim-chev{font-size:12px;color:var(–mute);transition:transform .2s;flex-shrink:0}
.fdim.open .fdim-chev{transform:rotate(180deg)}
.fdim-body{display:none;padding:0 12px 12px;border-top:1px solid var(–b2)}
.fdim.open .fdim-body{display:block}
.chip-row{display:flex;gap:5px;flex-wrap:wrap;padding-top:10px}
.fp{display:inline-flex;align-items:center;gap:4px;padding:7px 11px;border-radius:8px;background:var(–surf);border:1px solid var(–bdr);color:var(–t2);font-size:12px;font-weight:500;min-height:38px;transition:all .1s}
.fp:active{transform:scale(.95)}
.fp.on{background:var(–g2);border-color:var(–grn);color:var(–grn)}
.fp-c{font-family:var(–mono);font-size:9px;color:var(–mute)}
.fp.on .fp-c{color:rgba(0,230,118,.6)}
.dim-clear{display:block;width:100%;margin-top:7px;padding:7px;border-radius:7px;font-size:10px;color:var(–mute);font-family:var(–mono);border:1px solid var(–b2);text-align:center}

/* SONG ROWS */
.song-row{display:flex;align-items:center;gap:10px;padding:11px 16px;border-bottom:1px solid var(–b2);min-height:60px;-webkit-tap-highlight-color:transparent;transition:background .1s}
.song-row:active{background:var(–raise)}
.sr-num{font-family:var(–mono);font-size:10px;color:var(–mute);min-width:20px;text-align:right;flex-shrink:0}
.sr-inf{flex:1;min-width:0}
.sr-t{font-size:13px;font-weight:600;color:var(–text);margin-bottom:2px}
.sr-m{font-size:10px;color:var(–mute);font-family:var(–mono)}
.sr-r{display:flex;flex-direction:column;align-items:flex-end;gap:2px;flex-shrink:0}
.stg{font-size:8px;padding:2px 5px;border-radius:3px;white-space:nowrap;font-family:var(–mono)}
.stg-s{background:rgba(0,180,216,.1);color:#6dd4de;border:1px solid rgba(0,180,216,.2)}
.stg-l{background:rgba(155,89,182,.1);color:#c4a0ff;border:1px solid rgba(155,89,182,.2)}
.sr-fav{font-size:13px;color:var(–mute);padding:4px;flex-shrink:0;line-height:1}
.sr-fav.on{color:var(–gold)}
.sr-arr{color:var(–dim);font-size:12px;flex-shrink:0}
.alb-divider{padding:12px 16px 5px;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(–mute);font-family:var(–mono);border-top:1px solid var(–bdr);margin-top:6px}

/* ARTIST DETAIL */
.dtb{display:flex;align-items:center;gap:10px;padding:11px 16px;border-bottom:1px solid var(–bdr);position:sticky;top:0;z-index:10;background:rgba(9,9,15,.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px)}
.back-btn{display:flex;align-items:center;color:var(–grn);font-size:14px;font-weight:700;padding:6px 4px;margin:-6px -4px;min-width:44px;min-height:44px}
.back-ic{font-size:22px}
.dtb-nm{font-size:14px;font-weight:700;color:var(–acc);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.aib{padding:14px 16px;display:flex;gap:12px;align-items:flex-start;border-bottom:1px solid var(–bdr)}
.a-icon{width:52px;height:52px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:22px}
.a-t{flex:1;min-width:0}
.a-nm{font-size:16px;font-weight:700;margin-bottom:2px}
.a-era{font-size:9px;color:var(–mute);font-family:var(–mono);margin-bottom:4px}
.a-bio{font-size:11px;color:var(–t2);line-height:1.6}
.a-genres{display:flex;flex-wrap:wrap;gap:3px;margin-top:7px}
.pnote{padding:7px 16px;font-size:10px;color:var(–mute);font-family:var(–mono);background:var(–surf);border-bottom:1px solid var(–bdr);line-height:1.6}

/* CATALOG PROMPT STRIP */
.cps{border-bottom:1px solid var(–bdr)}
.cps-tabs{display:flex}
.cps-tab{flex:1;padding:9px 0;text-align:center;font-size:10px;font-family:var(–mono);letter-spacing:1px;text-transform:uppercase;color:var(–mute);border-bottom:2px solid transparent;transition:all .15s}
.cps-tab.on{color:var(–grn);border-bottom-color:var(–grn)}
.cps-body{padding:12px 16px;display:none}
.cps-body.on{display:block}
.cps-lbl{font-size:8px;letter-spacing:2px;text-transform:uppercase;font-family:var(–mono);color:var(–mute);margin-bottom:5px}
.cps-txt{font-size:11px;color:var(–t2);font-family:var(–mono);line-height:1.7;white-space:pre-wrap}
.cps-cp{display:block;width:100%;margin-top:8px;padding:8px;background:var(–g3);border:1px solid rgba(0,230,118,.22);color:var(–grn);border-radius:7px;font-size:10px;font-family:var(–mono);letter-spacing:1px;text-align:center;text-transform:uppercase}

/* PROMPT SHEET */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:200;display:none;align-items:flex-end;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}
.overlay.on{display:flex}
.sheet{width:100%;max-height:93vh;background:var(–card);border-radius:18px 18px 0 0;padding-bottom:calc(16px + var(–sab));overflow:hidden;display:flex;flex-direction:column;transform:translateY(100%);transition:transform .28s cubic-bezier(.32,1,.23,1);border-top:1px solid var(–bdr)}
.overlay.on .sheet{transform:translateY(0)}
.sh-handle{width:34px;height:4px;background:var(–dim);border-radius:2px;margin:10px auto 0;flex-shrink:0}
.sh-hd{padding:10px 18px;border-bottom:1px solid var(–bdr);flex-shrink:0;display:flex;justify-content:space-between;align-items:flex-start}
.sh-tw{flex:1;margin-right:10px}
.sh-title{font-size:16px;font-weight:700;color:var(–acc);line-height:1.2}
.sh-sub{font-size:10px;color:var(–mute);font-family:var(–mono);margin-top:2px}
.sh-close{color:var(–mute);font-size:24px;min-width:40px;min-height:40px;display:flex;align-items:center;justify-content:center}
.sh-lvl-tabs{display:flex;flex-shrink:0}
.slt{flex:1;padding:9px 0;text-align:center;font-size:9px;font-family:var(–mono);letter-spacing:1px;text-transform:uppercase;color:var(–mute);border-bottom:2px solid transparent;transition:all .15s}
.slt.on{color:var(–grn);border-bottom-color:var(–grn)}
.sh-body{overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1}
.slc{display:none;padding:12px 16px 4px}
.slc.on{display:block}
.sh-tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px}
.sht{font-size:9px;padding:3px 8px;border-radius:5px;min-height:28px;display:inline-flex;align-items:center;cursor:pointer}
.sh-dna{margin-bottom:10px;background:var(–surf);border:1px solid var(–bdr);border-radius:8px;padding:10px 12px}
.dna-lbl{font-size:8px;letter-spacing:2px;text-transform:uppercase;font-family:var(–mono);color:var(–mute);margin-bottom:4px}
.dna-txt{font-size:11px;color:var(–t2);line-height:1.7}
.pb{margin-bottom:10px}
.pb-lbl{font-size:9px;letter-spacing:2px;text-transform:uppercase;font-family:var(–mono);font-weight:600;margin-bottom:5px;display:flex;align-items:center;justify-content:space-between}
.pb-hint{font-size:8px;color:var(–mute);font-weight:400;letter-spacing:.5px;text-transform:none}
.pb-box{background:var(–surf);border:1px solid var(–bdr);border-radius:8px;overflow:hidden}
.pb-txt{padding:10px 12px;font-size:11px;color:#b0b0cc;font-family:var(–mono);line-height:1.8;white-space:pre-wrap;max-height:180px;overflow-y:auto;-webkit-overflow-scrolling:touch}
.cp-btn{display:flex;align-items:center;justify-content:center;gap:7px;width:calc(100% - 22px);margin:7px 11px 9px;padding:13px;background:var(–g3);border:1px solid rgba(0,230,118,.28);color:var(–grn);border-radius:10px;font-size:15px;font-weight:700;min-height:52px;transition:all .1s}
.cp-btn:active{background:var(–g2);transform:scale(.98)}

/* SEARCH */
.sg-lbl{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(–mute);font-family:var(–mono);padding:12px 16px 5px;border-bottom:1px solid var(–bdr)}
.sres{display:flex;align-items:center;gap:10px;padding:11px 16px;border-bottom:1px solid var(–b2);min-height:56px;-webkit-tap-highlight-color:transparent}
.sres:active{background:var(–raise)}
.sres-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.sres-c{flex:1;min-width:0}
.sres-tt{font-size:13px;font-weight:600;color:var(–text);margin-bottom:1px}
.sres-sb{font-size:10px;color:var(–mute);font-family:var(–mono)}
.sres-mx{font-size:10px;color:var(–t2);margin-top:2px;font-style:italic;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}

/* MANAGE ARTISTS */
.ma-card{margin:0 16px 10px;background:var(–card);border:1px solid var(–bdr);border-radius:10px;overflow:hidden}
.ma-card-hd{display:flex;align-items:center;gap:10px;padding:12px 16px}
.ma-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.ma-info{flex:1;min-width:0}
.ma-nm{font-size:13px;font-weight:700;color:var(–text)}
.ma-meta{font-size:10px;color:var(–mute);font-family:var(–mono)}
.ma-badge{font-size:8px;padding:2px 6px;border-radius:4px;font-family:var(–mono);letter-spacing:.5px}
.ma-built{background:var(–g2);color:var(–grn);border:1px solid rgba(0,230,118,.3)}
.ma-custom{background:rgba(155,89,182,.15);color:#9b59b6;border:1px solid rgba(155,89,182,.3)}
.ma-del{color:var(–red);font-size:13px;padding:6px;min-width:36px;min-height:36px;display:flex;align-items:center;justify-content:center}
.add-artist-box{margin:0 16px 12px;background:var(–card);border:1px solid var(–bdr);border-radius:10px;overflow:hidden}
.add-artist-hd{padding:12px 16px 8px;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-family:var(–mono);color:var(–mute);border-bottom:1px solid var(–b2)}
.add-artist-body{padding:12px 16px}
.add-artist-body p{font-size:11px;color:var(–t2);line-height:1.7;margin-bottom:10px}
.add-artist-body textarea{width:100%;min-height:120px;padding:10px 12px;background:var(–surf);border:1px solid var(–bdr);border-radius:8px;color:var(–text);font-size:11px;font-family:var(–mono);outline:none;resize:vertical;line-height:1.6}
.add-artist-body textarea:focus{border-color:var(–grn)}
.btn-grn{display:block;width:100%;padding:12px;background:var(–g2);border:2px solid var(–grn);color:var(–grn);border-radius:9px;font-size:13px;font-weight:700;letter-spacing:1px;text-align:center;margin-top:8px;transition:all .15s}
.btn-grn:active{transform:scale(.98)}
.btn-outline{display:inline-block;padding:8px 14px;background:var(–raise);border:1px solid var(–bdr);color:var(–t2);border-radius:8px;font-size:11px;font-family:var(–mono);letter-spacing:1px;text-transform:uppercase}
.export-row{display:flex;gap:8px;padding:12px 16px;border-top:1px solid var(–bdr)}

/* MY SONGS (own music) */
.ms-card{margin:0 16px 10px;background:var(–card);border:1px solid var(–bdr);border-radius:10px;overflow:hidden}
.ms-card-hd{padding:12px 16px 8px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(–b2)}
.ms-band-dot{width:10px;height:10px;border-radius:50%;background:var(–grn);flex-shrink:0}
.ms-band-nm{font-size:13px;font-weight:700;color:var(–acc)}
.ms-song-row{display:flex;align-items:flex-start;gap:10px;padding:10px 16px;border-bottom:1px solid var(–b2)}
.ms-song-t{font-size:13px;font-weight:600;color:var(–text);margin-bottom:2px}
.ms-song-s{font-size:10px;color:var(–t2);font-family:var(–mono);line-height:1.5}
.ms-del{color:var(–mute);font-size:14px;padding:4px;flex-shrink:0}
.band-color-btn{width:28px;height:28px;border-radius:50%;flex-shrink:0;border:2px solid var(–bdr);cursor:pointer}
.ff{margin-bottom:8px}
.ff label{font-size:9px;letter-spacing:1px;text-transform:uppercase;font-family:var(–mono);color:var(–mute);margin-bottom:3px;display:block}
.fi{width:100%;padding:8px 11px;background:var(–surf);border:1px solid var(–bdr);border-radius:7px;color:var(–text);font-size:12px;outline:none}
.fi:focus{border-color:var(–grn)}
.fi.ta{resize:vertical;min-height:56px;font-family:var(–mono);font-size:11px;line-height:1.5}
.ff-submit{width:100%;padding:10px;background:var(–g3);border:1px solid rgba(0,230,118,.25);color:var(–grn);border-radius:7px;font-size:11px;font-family:var(–mono);letter-spacing:1px;text-transform:uppercase;margin-top:4px}
.cons-btn{display:block;width:100%;padding:12px;background:var(–g2);border:2px solid var(–grn);color:var(–grn);border-radius:9px;font-size:12px;font-weight:700;letter-spacing:1px;text-align:center;margin:10px 0}
.cons-btn:active{transform:scale(.98)}
.cr{background:var(–surf);border:1px solid var(–bdr);border-radius:8px;padding:12px;margin-bottom:10px}
