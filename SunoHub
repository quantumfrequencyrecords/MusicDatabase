function addArtistFromJSON(){
var raw=document.getElementById(‘add-json-input’).value.trim();
if(!raw){showToast(‘Paste artist JSON first’);return;}
var parsed;
try{parsed=JSON.parse(raw);}catch(e){showToast(‘Invalid JSON — check for errors’);return;}
if(!parsed.id||!parsed.name){showToast(‘JSON must have “id” and “name” fields’);return;}
if(!parsed.songs||!parsed.songs.length){showToast(‘JSON must have a “songs” array’);return;}
// Remove existing custom with same id
customArtists=customArtists.filter(function(c){return c.id!==parsed.id;});
customArtists.push(parsed);
saveCustom();
rebuildDB();
document.getElementById(‘add-json-input’).value=’’;
buildManage();
showToast(‘✓ ‘+parsed.name+’ added — ‘+parsed.songs.length+’ songs’);
}

function deleteArtist(id){
customArtists=customArtists.filter(function(c){return c.id!==id;});
saveCustom();rebuildDB();buildManage();
showToast(‘Artist removed’);
}

function exportDB(){
var data=JSON.stringify(DB,null,2);
var blob=new Blob([data],{type:‘application/json’});
var url=URL.createObjectURL(blob);
var a=document.createElement(‘a’);a.href=url;a.download=‘suno_hub_database.json’;
document.body.appendChild(a);a.click();document.body.removeChild(a);
URL.revokeObjectURL(url);
showToast(‘Database exported!’);
}

function resetCustom(){
if(!confirm(‘Remove all custom artists? Built-in artists stay.’))return;
customArtists=[];saveCustom();rebuildDB();buildManage();showToast(‘Custom artists cleared’);
}

/* ═══════════════════════════════════════
MY SONGS (own music tracker)
═══════════════════════════════════════ */
function buildMySongs(){
var el=document.getElementById(‘mysongs-body’);
var bandsHTML=myBands.map(function(band,bi){
var songs=(band.songs||[]).map(function(s,si){
return’<div class="ms-song-row">’+
‘<div style="flex:1;min-width:0"><div class="ms-song-t">’+s.title+’</div>’+
‘<div class="ms-song-s">’+(s.style||’’)+(s.lyrics?’\n’+s.lyrics:’’)+’</div></div>’+
‘<button class="ms-del" onclick="delMySong('+bi+','+si+')">×</button>’+
‘</div>’;
}).join(’’);
var cps=(band.prompts||[]).slice(0,2).map(function(cp){
return’<div class="cr"><div class="cr-ts">’+cp.ts+’</div>’+
‘<div class="cr-lbl">Style Consistency</div><div class="cr-txt">’+cp.style+’</div>’+
‘<div class="cr-lbl">Lyric Consistency</div><div class="cr-txt">’+cp.lyric+’</div>’+
‘<div style="display:flex;gap:7px">’+
‘<button class="cr-cp" onclick="copyStr('+JSON.stringify(cp.style)+')">Copy Style</button>’+
‘<button class="cr-cp" onclick="copyStr('+JSON.stringify(cp.lyric)+')">Copy Lyric</button>’+
‘</div></div>’;
}).join(’’);
return’<div class="ms-card">’+
‘<div class="ms-card-hd">’+
‘<div class="ms-band-dot" style="background:'+(band.color||'var(--grn)')+'"></div>’+
‘<input style="flex:1;background:none;border:none;outline:none;color:var(--acc);font-size:14px;font-weight:700;font-family:var(--sans)" value="'+band.name+'" oninput="updBandName('+bi+',this.value)">’+
‘<input type="color" value="'+(band.color||'#00e676')+'" onchange="updBandColor('+bi+',this.value)" style="width:28px;height:28px;border-radius:50%;border:2px solid var(--bdr);background:none;cursor:pointer;padding:0" title="Band color">’+
‘</div>’+
(songs||’<div style="padding:10px 16px;font-size:11px;color:var(--mute);font-family:var(--mono)">No songs yet</div>’)+
‘<div style="padding:10px 16px 4px">’+
‘<button class="cons-btn" onclick="genConsistency('+bi+')">✦ Generate Consistency Prompt</button>’+
cps+
‘</div>’+
‘<div class="add-form-wrap"><div class="add-form-t">Add Song</div>’+
‘<div class="ff"><label>Song Name</label><input class="fi" id="ns-t-'+bi+'" placeholder="My New Song"></div>’+
‘<div class="ff"><label>Style Notes</label><input class="fi" id="ns-s-'+bi+'" placeholder="Country-pop, uptempo, acoustic guitar…"></div>’+
‘<div class="ff"><label>Theme / Lyric Notes</label><textarea class="fi ta" id="ns-l-'+bi+'" placeholder="What the song is about, emotional tone…"></textarea></div>’+
‘<button class="ff-submit" onclick="addMySong('+bi+')">+ Add Song</button>’+
‘</div>’+
‘</div>’;
}).join(’’);

el.innerHTML=bandsHTML+
‘<div style="padding:12px 16px 24px">’+
‘<button class="btn-outline" onclick="addBand()">+ Add Band</button>’+
‘</div>’;
}

function updBandName(bi,v){myBands[bi].name=v;saveBands();}
function updBandColor(bi,v){myBands[bi].color=v;saveBands();}
function addBand(){
myBands.push({id:‘b’+(Date.now()),name:‘New Band’,color:’#00e676’,songs:[],prompts:[]});
saveBands();buildMySongs();
}
function addMySong(bi){
var t=(document.getElementById(‘ns-t-’+bi)||{}).value;
if(!t||!t.trim()){showToast(‘Enter a song name’);return;}
var s=(document.getElementById(‘ns-s-’+bi)||{}).value||’’;
var l=(document.getElementById(‘ns-l-’+bi)||{}).value||’’;
myBands[bi].songs.push({title:t.trim(),style:s,lyrics:l});
saveBands();buildMySongs();showToast(‘Song added!’);
}
function delMySong(bi,si){myBands[bi].songs.splice(si,1);saveBands();buildMySongs();}

function genConsistency(bi){
var band=myBands[bi];
if(!band.songs||!band.songs.length){showToast(‘Add some songs first’);return;}
var btn=document.querySelectorAll(’.cons-btn’)[bi];if(btn)btn.textContent=‘Generating…’;
var summary=band.songs.map(function(s,i){
return (i+1)+’. “’+s.title+’”\n   Style: ‘+(s.style||‘not specified’)+’\n   Theme: ‘+(s.lyrics||‘not specified’);
}).join(’\n\n’);
callClaude(
‘You are a music production consultant. Analyze these songs and create two prompts. Format exactly as:\nSTYLE: [style prompt here]\n\nLYRIC: [lyric brief here]’,
‘Band: “’+band.name+’”\n\nSongs:\n’+summary+’\n\nCreate:\n1. STYLE: 150-250 char style prompt\n2. LYRIC: 100-200 word lyric brief’
).then(function(res){
var sm=res.match(/STYLE:\s*([\s\S]+?)(?:\n\nLYRIC:|$)/i);
var lm=res.match(/LYRIC:\s*([\s\S]+)/i);
if(!band.prompts)band.prompts=[];
band.prompts.unshift({ts:new Date().toLocaleString(),style:sm?sm[1].trim():’’,lyric:lm?lm[1].trim():’’});
if(band.prompts.length>3)band.prompts.pop();
saveBands();buildMySongs();showToast(‘Consistency prompt saved!’);
}).catch(function(){
// Fallback: build manually
var styles=band.songs.map(function(s){return s.style;}).filter(Boolean).join(’, ‘);
var themes=band.songs.map(function(s){return s.lyrics;}).filter(Boolean).join(’. ‘);
if(!band.prompts)band.prompts=[];
band.prompts.unshift({
ts:new Date().toLocaleString()+’ (offline)’,
style:styles||‘Contemporary music style based on ‘+band.name+’ catalog’,
lyric:themes?’Lyric themes from ‘+band.name+’: ’+themes.slice(0,300):’Authentic original songwriting for ’+band.name
});
if(band.prompts.length>3)band.prompts.pop();
saveBands();buildMySongs();showToast(‘Prompt saved (offline mode)’);
});
}

function callClaude(sys,user){
return fetch(‘https://api.anthropic.com/v1/messages’,{
method:‘POST’,headers:{‘Content-Type’:‘application/json’},
body:JSON.stringify({model:‘claude-sonnet-4-20250514’,max_tokens:600,system:sys,messages:[{role:‘user’,content:user}]})
}).then(function(r){return r.json();})
.then(function(d){return(d.content||[]).map(function(c){return c.text||’’;}).join(’’).trim();});
}

/* ═══════════════════════════════════════
SEARCH
═══════════════════════════════════════ */
document.getElementById(‘qi’).addEventListener(‘input’,function(){
var q=this.value.trim();
if(!q){if(view===‘search’)goTab(prevView||‘home’);return;}
doSearch(q);
});
function clearSearch(){document.getElementById(‘qi’).value=’’;if(view===‘search’)goTab(‘home’);}

function doSearch(q){
showScreen(‘search’);
document.querySelectorAll(’.tab’).forEach(function(t){t.classList.remove(‘on’);});
var ql=q.toLowerCase(),arts=[],songs=[];
DB.forEach(function(a){
if((a.name+’ ‘+(a.bio||’’)+’ ‘+(a.genres||[]).join(’ ‘)).toLowerCase().indexOf(ql)>=0)arts.push(a);
(a.songs||[]).forEach(function(s,i){
var txt=[s.title,s.album,s.vibe,s.dna,s.style_prompt,s.lyric_prompt,(s.tags&&s.tags.style||[]).join(’ ‘),(s.tags&&s.tags.lyric||[]).join(’ ‘)].join(’ ‘).toLowerCase();
if(txt.indexOf(ql)>=0){
var full=((s.style_prompt||’’)+’ ‘+(s.lyric_prompt||’’)).toLowerCase();
var mi=full.indexOf(ql),mx=’’;
if(mi>=0){var st2=Math.max(0,mi-22),en=Math.min(full.length,mi+ql.length+38);
mx=’…’+full.slice(st2,en).replace(new RegExp(q.replace(/[.*+?^${}()|[]\]/g,’\$&’),‘gi’),function(m){return’<b style="color:var(--grn)">’+m+’</b>’})+’…’;}
songs.push({a:a,s:s,i:i,mx:mx});
}
});
});
var ah=arts.map(function(a){return’<div class="sres" onclick="openArtist(\''+a.id+'\')"><span class="sres-dot" style="background:'+(a.color||'#666')+'"></span><div class="sres-c"><div class="sres-tt">’+a.name+’</div><div class="sres-sb">’+(a.genres||[]).slice(0,2).join(’ · ‘)+’ · ‘+(a.songs||[]).length+’ songs</div></div><span class="sr-arr">›</span></div>’;}).join(’’);
var sh=songs.map(function(x){return’<div class="sres" onclick="openSongSheet(DB.find(function(d){return d.id===\''+x.a.id+'\';}).songs['+x.i+'],DB.find(function(d){return d.id===\''+x.a.id+'\';}),'+x.i+')"><span class="sres-dot" style="background:'+(x.a.color||'#666')+'"></span><div class="sres-c"><div class="sres-tt">’+x.s.title+’</div><div class="sres-sb">’+x.a.name+’ · ‘+(x.s.album||’’)+’</div>’+(x.mx?’<div class="sres-mx">’+x.mx+’</div>’:’’)+’ </div><span class="sr-arr">›</span></div>’;}).join(’’);
var tot=arts.length+songs.length;
document.getElementById(‘search-body’).innerHTML=
(arts.length?’<div class="sg-lbl">Artists (’+arts.length+’)</div>’+ah:’’)+
(songs.length?’<div class="sg-lbl">Songs (’+songs.length+’)</div>’+sh:’’)+
(tot===0?’<div class="empty" style="padding-top:40px"><div class="empty-ic">🔍</div><h3>No Results</h3><p>Try moods, instruments, or any word from the prompts.</p></div>’:’’);
}

/* ═══════════════════════════════════════
NAVIGATION
═══════════════════════════════════════ */
function showScreen(id){
document.querySelectorAll(’.screen’).forEach(function(s){s.classList.remove(‘on’);});
var el=document.getElementById(‘s-’+id);if(el)el.classList.add(‘on’);
document.getElementById(‘content’).scrollTop=0;
view=id;
}
function goTab(tab){
prevView=view;
document.querySelectorAll(’.tab’).forEach(function(t){t.classList.remove(‘on’);});
var btn=document.getElementById(‘tab-’+tab);if(btn)btn.classList.add(‘on’);
showScreen(tab);
if(tab===‘favs’)buildFavs();
if(tab===‘manage’)buildManage();
if(tab===‘mysongs’)buildMySongs();
}
function goBack(){
goTab([‘songs’,‘browse’].indexOf(prevView)>=0?prevView:‘home’);
curArtist=null;
}

/* ═══════════════════════════════════════
COPY
═══════════════════════════════════════ */
function copyById(id){var el=document.getElementById(id);if(el)copyStr(el.textContent.trim());}
function copyStr(text){
if(!text)return;
if(navigator.clipboard&&navigator.clipboard.writeText){
navigator.clipboard.writeText(text).then(function(){showToast(‘✓ Copied!’);}).catch(function(){legacyCopy(text);});
}else{legacyCopy(text);}
}
function legacyCopy(text){
var ta=document.createElement(‘textarea’);ta.value=text;
ta.style.cssText=‘position:fixed;top:-9999px;left:-9999px;opacity:0;font-size:16px’;
document.body.appendChild(ta);ta.focus();ta.select();ta.setSelectionRange(0,ta.value.length);
try{document.execCommand(‘copy’);showToast(‘✓ Copied!’);}catch(e){}
document.body.removeChild(ta);
}
function showToast(msg){
var t=document.getElementById(‘toast’);t.textContent=msg||‘✓ Copied!’;
t.classList.add(‘on’);setTimeout(function(){t.classList.remove(‘on’);},2500);
}

